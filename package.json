{
  "name": "scoremyprompt",
  "version": "1.0.0",
  "description": "Grade Your AI Prompt in 30 Seconds — ScoreMyPrompt",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/check-env.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "validate": "npm run typecheck && npm run lint && npm run test && npm run build",
    "verify": "npm run typecheck && npm run lint && npm run build",
    "precommit": "npm run typecheck && npm run lint",
    "deploy:check": "npm run verify && echo 'Ready to deploy!'"
  },
  "dependencies": {
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@vercel/og": "^0.5.20",
    "axios": "^1.6.2",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^20.3.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.52.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.31",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.6",
    "ts-jest": "^29.4.6"
  }
}
