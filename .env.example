# ─── AI API ───
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_...                    # Stripe Dashboard → Developers → API keys
STRIPE_WEBHOOK_SECRET=whsec_...                  # Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_PRICE_ID=price_...                        # Regular price: $4.99/mo
STRIPE_INTRO_PRICE_ID=price_...                  # (Optional) Intro price: $2.99/mo — if using separate price
STRIPE_INTRO_COUPON_ID=...                       # Stripe Coupon ID: $2 off for 3 months (repeating)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...   # Stripe Dashboard → Developers → API keys (Publishable)

# ─── Application URLs ───
NEXT_PUBLIC_BASE_URL=https://scoremyprompt.app   # Production URL (change to localhost:3000 for dev)
NEXT_PUBLIC_APP_URL=https://scoremyprompt.app
NEXT_PUBLIC_API_URL=https://scoremyprompt.app/api

# ─── Upstash Redis (Rate Limiting) ───
UPSTASH_REDIS_REST_URL=https://...upstash.io     # Upstash Console → Database → REST URL
UPSTASH_REDIS_REST_TOKEN=AX...                   # Upstash Console → Database → REST Token

# ─── Analytics (PostHog) ───
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key

# ─── Error Tracking (Sentry) ───
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# ─── Newsletter (Resend) ───
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=newsletter@scoremyprompt.com

# ─── Internal API (N8N webhook auth) ───
INTERNAL_API_KEY=generate-random-32-char-string
