# ═══════════════════════════════════════════════
# ScoreMyPrompt N8N Stack — Environment Variables
# ═══════════════════════════════════════════════

# ─── N8N Configuration ───
N8N_USER=admin
N8N_PASSWORD=your_secure_password
N8N_HOST=localhost
N8N_ENCRYPTION_KEY=generate-random-32-char-string
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=America/New_York

# ─── Database ───
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your_secure_db_password

# ─── 3-Tier AI API Keys ───
# Tier 1: Groq 70B free API (55% of tasks — drafts, summaries, translations)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key

# Tier 2: Ollama 3B local (30% — hashtags, captions, reformatting)
# Auto-configured via Docker, no key needed
# Pull model after first start: docker exec smp-ollama ollama pull llama3.2:3b

# Tier 3: Claude Max (15% — deep analysis, strategy)
# Only needed if using Claude API in workflows
# ANTHROPIC_API_KEY=sk-ant-your_key

# ─── Cloudflare Tunnel (for external webhook access) ───
# Create tunnel: cloudflared tunnel create smp-n8n
# Start with: docker compose --profile tunnel up -d
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token

# ─── Google Sheets (Content Calendar) ───
# Service account: https://console.cloud.google.com/iam-admin/serviceaccounts
# Share spreadsheet with the service account email
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY=your_private_key
# GOOGLE_SHEETS_ID=your_spreadsheet_id

# ─── Resend (Newsletter — WF-4) ───
# Get key: https://resend.com/api-keys
# RESEND_API_KEY=re_your_resend_api_key
# RESEND_FROM_EMAIL=newsletter@scoremyprompt.com

# ─── ScoreMyPrompt App ───
# SCOREMYPROMPT_URL=https://scoremyprompt.com
# SCOREMYPROMPT_API_KEY=your_internal_api_key
